# ==========================================
# POSTGRESQL CONFIGURATION
# ==========================================
POSTGRES_USER=postgres
POSTGRES_PASSWORD=postgres
POSTGRES_DB=inventory_db

# ==========================================
# BACKEND API CONFIGURATION
# ==========================================
# Inside the docker-compose bridge network, the hostname is 'postgres'
DATABASE_URL=postgresql://postgres:postgres@postgres:5432/inventory_db
PORT=8000
HOST=0.0.0.0

# ==========================================
# FRONTEND CONFIGURATION
# ==========================================
# The API URL that the client browser will query.
# Locally, this is the exposed port of the backend.
VITE_API_URL=http://localhost:8000
